// ── API KEY ──
function saveApiKey(){
  const k=document.getElementById('apiKeyInput').value.trim();
  if(!k.startsWith('sk-ant')){alert('APIキーの形式が正しくありません（sk-ant... で始まるキーを入力してください）');return;}
