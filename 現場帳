}

// ── RECEIPT CAMERA ──
function onImageSelected(e){
  const file=e.target.files[0];
  if(!file)return;
  const reader=new FileReader();
  reader.onload=ev=>{
    currentImg=ev.target.result;
    document.getElementById('imgPreview').src=currentImg;
    document.getElementById('imgPreviewWrap').style.display='block';
    if(apiKey) readReceiptWithAI(currentImg);
    else{
      document.getElementById('aiStatus').textContent='📷 画像を保存しました。金額・日付を手入力してください。';
      document.getElementById('aiStatus').className='ai-status';
    }
  };
  reader.readAsDataURL(file);
}

function removeImage(){
  currentImg=null;
  document.getElementById('imgPreviewWrap').style.display='none';
  document.getElementById('imgPreview').src='';
  document.getElementById('aiStatus').textContent='';
  document.getElementById('camInput').value='';
}

async function readReceiptWithAI(dataUrl){
  const st=document.getElementById('aiStatus');
  st.textContent='🤖 AI読み取り中...';
  st.className='ai-status loading';
  try{
    const base64=dataUrl.split(',')[1];
    const mediaType=dataUrl.split(';')[0].split(':')[1];
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json','x-api-key':apiKey,'anthropic-version':'2023-06-01'},
      body:JSON.stringify({
        model:'claude-opus-4-5',
        max_tokens:300,
        messages:[{
          role:'user',
          content:[
            {type:'image',source:{type:'base64',media_type:mediaType,data:base64}},
            {type:'text',text:'この領収書・レシートから以下をJSON形式のみで返してください。他のテキストは一切不要。{"shop":"店名","amount":税抜金額の数値,"tax_rate":0.10か0.08か0,"date":"YYYY-MM-DD形式","description":"内容の簡潔な説明"}。金額が税込のみ表示なら税抜に変換（10%なら÷1.1）。日付が不明なら""。'}
          ]
        }]
      })
    });
    const data=await res.json();
    if(data.error) throw new Error(data.error.message);
    const text=data.content[0].text.trim();
    const json=JSON.parse(text.replace(/```json|```/g,'').trim());
    if(json.shop) document.getElementById('rShop').value=json.shop;
    if(json.amount) document.getElementById('rAmt').value=Math.round(json.amount);
    if(json.tax_rate!==undefined) document.getElementById('rTaxRate').value=json.tax_rate;
    if(json.date) document.getElementById('rDate').value=json.date;
    if(json.description && !document.getElementById('rDesc').value) document.getElementById('rDesc').value=json.description;
    updateRP();
    st.textContent='✅ AI読み取り完了。内容を確認してください。';
    st.className='ai-status done';
  }catch(err){
    st.textContent='⚠️ 読み取り失敗。手入力してください。（'+err.message+')';
    st.className='ai-status err';
  }
}

function updateRP(){
  const amt=parseFloat(document.getElementById('rAmt').value)||0;
