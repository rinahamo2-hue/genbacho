let sites=loadData(), expenses=loadExpenses(), quotes=loadQuotes();
let taxDisplay='excl', selectedPay='', selectedCat='';
let currentImg=null; // base64
let apiKey = localStorage.getItem('genbacho_apikey') || '';
const TAX=0.10;

// ── YAYOI ──
const YAYOI={
  '外注工賃':{d:'外注工賃',c:'未払金'},'材料費':{d:'材料費',c:'未払金'},
  '燃料費':{d:'燃料費',c:'未払金'},'車両費':{d:'車両費',c:'未払金'},
  '工具器具費':{d:'工具器具費',c:'未払金'},'地代家賃':{d:'地代家賃',c:'未払金'},
  '通信費':{d:'通信費',c:'未払金'},'損害保険料':{d:'損害保険料',c:'未払金'},
  '交際費':{d:'交際費',c:'未払金'},'消耗品費':{d:'消耗品費',c:'未払金'},
  '旅費交通費':{d:'旅費交通費',c:'未払金'},'新聞図書費':{d:'新聞図書費',c:'未払金'},
  '雑費':{d:'雑費',c:'未払金'},
};
const TAXCODE={0.10:'課税仕入10%',0.08:'課税仕入8%',0:'対象外'};

// ── UTILS ──
const fmt=n=>'¥'+Math.round(n).toLocaleString('ja-JP');
const fmtN=n=>Math.round(n).toLocaleString('ja-JP');
const fmtD=d=>d?d.replace(/-/g,'/'):'';

function toggleTax(){
  taxDisplay=taxDisplay==='excl'?'incl':'excl';
  document.getElementById('taxLabel').textContent=taxDisplay==='excl'?'税抜':'税込';
