// ── PDF: QUOTE ──
function exportQuotePDF(){
  const to=document.getElementById('qTo').value||'（見積先）';
  const date=document.getElementById('qDate').value||'—';
  const expiry=document.getElementById('qExpiry').value||'—';
  const siteName=document.getElementById('qSiteName').value||'（工事名）';
  const work=document.getElementById('qWork').value||'—';
  const amt=parseFloat(document.getElementById('qAmt').value)||0;
  const note=document.getElementById('qNote').value||'';
  if(amt===0){alert('見積金額を入力してください');return;}
  generateQuotePDFDoc(to,date,expiry,siteName,work,amt,note);
}
function exportSingleQuotePDF(id){
  const q=quotes.find(x=>x.id===id);if(!q)return;
  generateQuotePDFDoc(q.to||'（見積先）',q.date||'—',q.expiry||'—',q.siteName,q.work||'—',q.amt,q.note||'');
}
function generateQuotePDFDoc(to,date,expiry,siteName,work,amt,note){
