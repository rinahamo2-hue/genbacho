  const W=210,M=20;let y=20;
  const tax=Math.round(amt*TAX),total=amt+tax;
  doc.setFontSize(22);doc.setFont('helvetica','bold');doc.text('ESTIMATE',M,y);
  doc.setFontSize(9);doc.setFont('helvetica','normal');doc.setTextColor(120);
  doc.text('見積書',M,y+6);
  doc.text('Date: '+date,W-M,y,{align:'right'});
  doc.text('Valid until: '+expiry,W-M,y+5,{align:'right'});
  y+=14;doc.setDrawColor(30,30,30);doc.setLineWidth(0.5);doc.line(M,y,W-M,y);y+=8;
  doc.setFontSize(8);doc.setTextColor(100);doc.text('ESTIMATE FOR',M,y);y+=4;
  doc.setFontSize(12);doc.setTextColor(20);doc.setFont('helvetica','bold');doc.text(to,M,y);
  doc.setFont('helvetica','normal');y+=10;
  doc.setFontSize(9);doc.setTextColor(100);doc.text('SITE / PROJECT',M,y);y+=4;
  doc.setFontSize(12);doc.setTextColor(20);doc.setFont('helvetica','bold');doc.text(siteName,M,y);doc.setFont('helvetica','normal');y+=10;
  doc.setFillColor(30,30,30);doc.rect(M,y,W-M*2,8,'F');
  doc.setFontSize(8);doc.setTextColor(255);
  doc.text('DESCRIPTION',M+3,y+5.5);doc.text('EXCL. TAX',130,y+5.5,{align:'right'});doc.text('TOTAL (INCL.)',W-M-2,y+5.5,{align:'right'});
  y+=8;doc.setTextColor(20);doc.setFontSize(10);doc.setFillColor(248,246,241);doc.rect(M,y,W-M*2,9,'F');
  doc.text(work,M+3,y+6);doc.text('JPY '+fmtN(amt),130,y+6,{align:'right'});doc.text('JPY '+fmtN(total),W-M-2,y+6,{align:'right'});
  y+=9;doc.setDrawColor(200);doc.line(M,y,W-M,y);y+=10;
  doc.setFontSize(9);doc.setTextColor(100);doc.text('Subtotal (excl. tax):',140,y,{align:'right'});doc.setTextColor(20);doc.text('JPY '+fmtN(amt),W-M-2,y,{align:'right'});y+=6;
  doc.setTextColor(100);doc.text('Consumption Tax (10%):',140,y,{align:'right'});doc.setTextColor(60,80,180);doc.text('JPY '+fmtN(tax),W-M-2,y,{align:'right'});y+=8;
  doc.setLineWidth(0.3);doc.setDrawColor(30,30,30);doc.line(120,y,W-M,y);y+=6;
  doc.setFontSize(13);doc.setFont('helvetica','bold');doc.setTextColor(185,28,28);
  doc.text('TOTAL ESTIMATE',140,y,{align:'right'});doc.text('JPY '+fmtN(total),W-M-2,y,{align:'right'});
  doc.setFont('helvetica','normal');y+=14;
  if(note){doc.setFontSize(9);doc.setTextColor(100);doc.text('Note: ',M,y);doc.setTextColor(20);doc.text(note,M+15,y);y+=8;}
  doc.setFontSize(8);doc.setTextColor(150);doc.text('* This estimate is valid until '+expiry+'. Prices are subject to change after expiry.',M,y);
  doc.save(`見積書_${siteName}_${date}.pdf`);
}

// ── PDF: SUMMARY ──
function exportSummaryPDF(){
  if(!sites.length&&!expenses.length){alert('データがありません');return;}
  const {jsPDF}=window.jspdf;
  const doc=new jsPDF({orientation:'portrait',unit:'mm',format:'a4'});
  const W=210,M=20;let y=20;
  const totalRev=sites.reduce((a,s)=>a+s.rev,0);
  const totalRevTax=Math.round(totalRev*TAX);
  const sitesExp=sites.reduce((a,s)=>a+s.sub+s.mat,0);
  const otherExp=expenses.reduce((a,e)=>a+e.amt,0);
  const totalExp=sitesExp+otherExp;
  const income=totalRev-totalExp;
  const totalExpTax=expenses.reduce((a,e)=>a+e.tax,0)+sitesExp*TAX;
  const payTax=Math.max(0,totalRevTax-totalExpTax);
  const today=new Date().toLocaleDateString('ja-JP');
  doc.setFontSize(18);doc.setFont('helvetica','bold');doc.text('P&L SUMMARY',M,y);
  doc.setFontSize(9);doc.setFont('helvetica','normal');doc.setTextColor(120);
  doc.text('Genbacho v4 — Construction Accounting',M,y+6);doc.text('Generated: '+today,W-M,y+6,{align:'right'});
  y+=14;doc.setDrawColor(30,30,30);doc.setLineWidth(0.5);doc.line(M,y,W-M,y);y+=10;
  const td=[
    [[34,100,56],'売上高（税抜）',fmtN(totalRev)],
    [[30,64,175],'　仮受消費税',fmtN(totalRevTax)],
    [[185,28,28],'外注工賃＋材料費（現場）',fmtN(sitesExp)],
    [[185,28,28],'その他経費',fmtN(otherExp)],
    [[30,64,175],'　仮払消費税',fmtN(Math.round(totalExpTax))],
    [[22,101,52],'所得（概算）',fmtN(income)],
    [[146,64,14],'消費税 納付額（概算）',fmtN(payTax)],
  ];
  td.forEach(([c,label,val])=>{
    doc.setFillColor(...c);doc.rect(M,y-4,3,7,'F');
    doc.setFontSize(10);doc.setTextColor(30);doc.text(label,M+6,y);
    doc.setFont('helvetica','bold');doc.text('JPY '+val,W-M-2,y,{align:'right'});
    doc.setFont('helvetica','normal');doc.setDrawColor(220);doc.setLineWidth(0.2);doc.line(M,y+3,W-M,y+3);y+=10;
  });
  y+=6;doc.setFontSize(10);doc.setFont('helvetica','bold');doc.setTextColor(30);
  doc.text('SITES ('+sites.length+')',M,y);doc.setFont('helvetica','normal');y+=4;
  doc.setLineWidth(0.3);doc.setDrawColor(30,30,30);doc.line(M,y,W-M,y);y+=6;
  sites.forEach(s=>{
    doc.setFontSize(9);doc.setTextColor(30);doc.text(s.name,M,y);
    doc.setTextColor(22,101,52);doc.text('Gross: JPY '+fmtN(s.profit)+' ('+s.margin+'%)',W-M-2,y,{align:'right'});y+=6;
  });
  doc.save('損益サマリー_現場帳.pdf');
}

