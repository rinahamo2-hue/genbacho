// ── CSV ──
function dlCSV(filename,rows){
  const bom='\uFEFF';
  const csv=bom+rows.map(r=>r.map(c=>`"${String(c).replace(/"/g,'""')}"`).join(',')).join('\r\n');
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8;'}));
  a.download=filename;a.click();
}
function exportExpCSV(){
  if(!expenses.length){alert('経費データがありません');return;}
  const hd=['伝票No','年月日','借方科目','借方補助科目','借方税区分','借方金額','借方消費税額','貸方科目','貸方補助科目','貸方税区分','貸方金額','貸方消費税額','摘要','番号','付箋1','付箋2'];
  const rows=[hd];
  expenses.forEach((e,i)=>{
    const ac=YAYOI[e.cat]||{d:e.cat,c:'未払金'};
    const tc=TAXCODE[e.taxRate]||'対象外';
    const sn=e.siteId?(sites.find(s=>s.id==e.siteId)?.name||''):'';
    const memo=sn?`${sn} ${e.desc}`:e.desc;
    rows.push([i+1,fmtD(e.date),ac.d,'',tc,Math.round(e.amt),Math.round(e.tax),ac.c,'','',Math.round(e.total),'',memo,e.invNo||'','','']);
  });
  dlCSV('経費仕訳_弥生会計.csv',rows);
}
function exportSiteCSV(){
  if(!sites.length){alert('現場データがありません');return;}
  const hd=['伝票No','年月日','借方科目','借方補助科目','借方税区分','借方金額','借方消費税額','貸方科目','貸方補助科目','貸方税区分','貸方金額','貸方消費税額','摘要','番号','付箋1','付箋2'];
  const rows=[hd];let no=1;
  sites.forEach(s=>{
    const d=fmtD(s.end||s.start);const rt=Math.round(s.rev*TAX);
    rows.push([no++,d,'売掛金','','課税売上10%',Math.round(s.rev+rt),rt,'売上高','','',Math.round(s.rev+rt),'',s.name,'','','']);
    if(s.sub>0){const st=Math.round(s.sub*TAX);rows.push([no++,d,'外注工賃','','課税仕入10%',Math.round(s.sub),st,'未払金','','',Math.round(s.sub+st),'',s.name,'','','']);}
    if(s.mat>0){const mt=Math.round(s.mat*TAX);rows.push([no++,d,'材料費','','課税仕入10%',Math.round(s.mat),mt,'未払金','','',Math.round(s.mat+mt),'',s.name,'','','']);}
  });
  dlCSV('売上仕訳_弥生会計.csv',rows);
}
function exportDetailCSV(){
  if(!expenses.length&&!sites.length){alert('データがありません');return;}
  const hd=['日付','勘定科目','摘要','現場名','税抜金額','消費税','税込金額','税区分','インボイス番号','領収書'];
  const rows=[hd];
  expenses.forEach(e=>{
    const sn=e.siteId?(sites.find(s=>s.id==e.siteId)?.name||'現場外'):'現場外';
    rows.push([e.date||'',e.cat,e.desc,sn,Math.round(e.amt),Math.round(e.tax),Math.round(e.total),TAXCODE[e.taxRate]||'対象外',e.invNo||'',e.fromReceipt?'○':'']);
  });
  dlCSV('経費明細_確定申告用.csv',rows);
}

