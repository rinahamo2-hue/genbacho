function renderSummary(){
  const totalRev=sites.reduce((a,s)=>a+s.rev,0);
  const totalRevTax=totalRev*TAX;
  const sitesExpAmt=sites.reduce((a,s)=>a+s.sub+s.mat,0);
  const expAmt=expenses.reduce((a,e)=>a+e.amt,0);
  const totalExp=sitesExpAmt+expAmt;
  const totalExpTax=expenses.reduce((a,e)=>a+e.tax,0)+sitesExpAmt*TAX;
  document.getElementById('sumCount').textContent=sites.length;
  document.getElementById('sumRev').textContent=fmt(taxDisplay==='excl'?totalRev:totalRev+totalRevTax);
  document.getElementById('sumExp').textContent=fmt(totalExp);
  document.getElementById('sumProfit').textContent=fmt(totalRev-totalExp);
  document.getElementById('sumTax').textContent=fmt(totalRevTax-totalExpTax);
}

