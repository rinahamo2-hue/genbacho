function renderAcc(){
  const totalRev=sites.reduce((a,s)=>a+s.rev,0);
  const totalRevTax=totalRev*TAX;
  const totalSub=sites.reduce((a,s)=>a+s.sub,0)+expenses.filter(e=>e.cat==='外注工賃').reduce((a,e)=>a+e.amt,0);
  const totalMat=sites.reduce((a,s)=>a+s.mat,0)+expenses.filter(e=>e.cat==='材料費').reduce((a,e)=>a+e.amt,0);
  const other=expenses.filter(e=>e.cat!=='外注工賃'&&e.cat!=='材料費').reduce((a,e)=>a+e.amt,0);
  const totalExpTax=expenses.reduce((a,e)=>a+e.tax,0)+sites.reduce((a,s)=>a+s.sub+s.mat,0)*TAX;
  const income=totalRev-totalSub-totalMat-other;
  const invTax=expenses.filter(e=>e.invNo&&e.invNo.startsWith('T')).reduce((a,e)=>a+e.tax,0);
  document.getElementById('accRev').textContent=fmt(totalRev);
  document.getElementById('accRevTax').textContent=fmt(totalRevTax);
  document.getElementById('accSub').textContent=fmt(totalSub);
  document.getElementById('accMat').textContent=fmt(totalMat);
  document.getElementById('accOther').textContent=fmt(other);
  document.getElementById('accExpTax').textContent=fmt(totalExpTax);
  document.getElementById('accIncome').textContent=fmt(income);
  document.getElementById('ctRev').textContent=fmt(totalRevTax);
  document.getElementById('ctExp').textContent=fmt(totalExpTax);
  document.getElementById('ctInv').textContent=fmt(invTax);
  document.getElementById('ctPay').textContent=fmt(Math.max(0,totalRevTax-totalExpTax));
  const cats={};
  expenses.forEach(e=>{cats[e.cat]=(cats[e.cat]||0)+e.amt;});
  sites.forEach(s=>{
    if(s.sub>0)cats['外注工賃']=(cats['外注工賃']||0)+s.sub;
    if(s.mat>0)cats['材料費']=(cats['材料費']||0)+s.mat;
  });
  const bd=document.getElementById('catBD');
  bd.innerHTML='<div class="ar hd"><span class="al">勘定科目</span><span class="av">金額（税抜）</span></div>';
  Object.entries(cats).sort((a,b)=>b[1]-a[1]).forEach(([cat,amt])=>{
    const r=document.createElement('div');r.className='ar';
    r.innerHTML=`<span class="al">${cat}</span><span class="av neg">${fmt(amt)}</span>`;
    bd.appendChild(r);
  });
  if(!Object.keys(cats).length){
    const r=document.createElement('div');r.className='ar';
    r.innerHTML='<span class="al" style="color:var(--steel)">経費データなし</span><span class="av">—</span>';
    bd.appendChild(r);
  }
}

