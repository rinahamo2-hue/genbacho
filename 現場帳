<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>現場帳 — 建設業会計</title>
<meta name="description" content="建設業向け現場別原価管理・会計アプリ">
<meta name="theme-color" content="#111827">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="現場帳">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icon-192.png">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=DM+Mono:wght@400;500;600&display=swap');
:root {
  --ink:#111827;--ink2:#1f2937;--paper:#f8f6f1;--paper2:#f0ece3;--paper3:#e8e3d8;
  --white:#fff;--red:#b91c1c;--red-l:#fee2e2;--green:#166534;--gm:#16a34a;--green-l:#dcfce7;
  --blue:#1e40af;--blue-l:#dbeafe;--gold:#92400e;--gold-l:#fef3c7;--steel:#6b7280;--border:#d1d5db;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Noto Sans JP',sans-serif;background:var(--paper);color:var(--ink);min-height:100vh;font-size:14px;}

/* HEADER */
.hdr{background:var(--ink);padding:0 16px;position:sticky;top:0;z-index:200;}
.hdr-top{display:flex;align-items:center;justify-content:space-between;padding:11px 0 0;}
.logo{font-size:19px;font-weight:900;color:#fff;letter-spacing:.04em;}
.logo em{color:#f87171;font-style:normal;}
.logo-sub{font-size:10px;color:#6b7280;font-family:'DM Mono',monospace;margin-top:1px;}
.tax-tog{display:flex;align-items:center;gap:5px;background:var(--ink2);border-radius:20px;padding:5px 10px;font-size:11px;color:#9ca3af;cursor:pointer;user-select:none;border:1px solid #374151;}
.tax-tog span{color:#f87171;font-weight:700;font-family:'DM Mono',monospace;}
.nav{display:flex;margin-top:9px;border-bottom:2px solid #1f2937;overflow-x:auto;}
.tab{padding:8px 13px;font-size:11px;font-weight:700;color:#6b7280;cursor:pointer;letter-spacing:.05em;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .15s;white-space:nowrap;flex-shrink:0;}
.tab.active{color:#f87171;border-bottom-color:#f87171;}

/* SUMMARY */
.sbar{background:var(--ink2);padding:9px 16px;display:grid;grid-template-columns:repeat(5,1fr);gap:4px;border-bottom:1px solid #374151;}
.si{text-align:center;}
.sl{font-size:9px;color:#6b7280;font-family:'DM Mono',monospace;margin-bottom:2px;text-transform:uppercase;}
.sv{font-size:12px;font-weight:700;font-family:'DM Mono',monospace;color:#f3f4f6;}
.sv.red{color:#f87171;}.sv.green{color:#86efac;}.sv.gold{color:#fcd34d;}

/* PAGES */
.page{display:none;padding:16px;max-width:640px;margin:0 auto;padding-bottom:60px;}
.page.active{display:block;}
.sec{font-size:10px;font-weight:700;letter-spacing:.12em;color:var(--steel);text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.sec::after{content:'';flex:1;height:1px;background:var(--border);}

/* CARD / FORM */
.card{background:var(--white);border:1px solid var(--border);border-radius:6px;padding:16px;margin-bottom:16px;box-shadow:0 1px 3px rgba(0,0,0,.06);}
.fr{margin-bottom:12px;}.fr:last-child{margin-bottom:0;}
.fl{display:block;font-size:10px;font-weight:700;letter-spacing:.08em;color:var(--steel);text-transform:uppercase;margin-bottom:4px;}
.fi{width:100%;padding:9px 11px;border:1px solid var(--border);border-radius:4px;font-size:14px;font-family:'Noto Sans JP',sans-serif;background:var(--paper);color:var(--ink);appearance:none;transition:border-color .15s,background .15s;}
.fi:focus{outline:none;border-color:#f87171;background:#fff;}
.fi.mono{font-family:'DM Mono',monospace;font-size:15px;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;}

/* CHIPS */
.chips{display:flex;flex-wrap:wrap;gap:6px;}
.chip{padding:6px 10px;border:1px solid var(--border);border-radius:3px;font-size:11px;font-family:'Noto Sans JP',sans-serif;font-weight:500;color:var(--steel);cursor:pointer;background:var(--paper);transition:all .12s;white-space:nowrap;}
.chip:hover{border-color:#f87171;color:var(--red);}
.chip.sel{background:var(--red);border-color:var(--red);color:#fff;font-weight:700;}

/* PREVIEW */
.prev{background:var(--paper2);border-left:3px solid #f87171;padding:11px 13px;border-radius:0 4px 4px 0;margin-top:12px;}
.pr{display:flex;justify-content:space-between;font-size:12px;margin-bottom:3px;color:var(--steel);}
.pr .pv{font-family:'DM Mono',monospace;font-weight:600;color:var(--ink);}
.pr.tot{border-top:1px solid var(--border);margin-top:7px;padding-top:7px;font-size:14px;}
.pr.tot .pv{color:var(--gm);}
.pr.ptax .pv{color:var(--blue);}
.pr.prate .pv{color:var(--gold);}

/* BUTTONS */
.btn{width:100%;padding:12px;border:none;border-radius:4px;font-size:14px;font-weight:700;font-family:'Noto Sans JP',sans-serif;cursor:pointer;transition:opacity .15s,transform .1s;letter-spacing:.04em;}
.btn:active{transform:translateY(1px);}
.btn-p{background:var(--red);color:#fff;box-shadow:0 2px 0 #7f1d1d;}.btn-p:hover{opacity:.88;}
.btn-s{background:var(--ink);color:#fff;}
.btn-o{background:none;border:1px solid var(--border);color:var(--steel);}
.btn-o:hover{border-color:var(--ink);color:var(--ink);}
.btn-g{background:#059669;color:#fff;}
.bsm{padding:5px 10px;font-size:11px;border-radius:3px;border:1px solid var(--border);background:none;color:var(--steel);cursor:pointer;font-family:'Noto Sans JP',sans-serif;}
.bsm:hover{border-color:var(--red);color:var(--red);}
.br2{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:12px;}

/* TAG */
.tag{font-size:10px;padding:2px 7px;border-radius:2px;font-weight:700;}
.tr{background:var(--red-l);color:var(--red);}
.tg{background:var(--green-l);color:var(--green);}
.tb{background:var(--blue-l);color:var(--blue);}
.tgo{background:var(--gold-l);color:var(--gold);}

/* SITE CARD */
.sc{background:var(--white);border:1px solid var(--border);border-radius:6px;overflow:hidden;margin-bottom:10px;box-shadow:0 1px 3px rgba(0,0,0,.05);animation:fu .2s ease;}
@keyframes fu{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.sc-h{background:var(--ink);padding:11px 14px;display:flex;justify-content:space-between;align-items:flex-start;}
.sc-n{font-size:14px;font-weight:700;color:#fff;}
.sc-d{font-size:10px;color:#9ca3af;font-family:'DM Mono',monospace;margin-top:2px;}
.sc-al{font-size:9px;color:#9ca3af;text-align:right;}
.sc-av{font-size:16px;font-weight:700;color:#fff;font-family:'DM Mono',monospace;}
.sc-b{padding:10px 14px;}
.sc-r{display:flex;justify-content:space-between;font-size:12px;color:var(--steel);margin-bottom:3px;}
.sc-r .sv{font-family:'DM Mono',monospace;font-weight:600;color:var(--ink);}
.sc-tags{display:flex;gap:5px;margin-top:8px;flex-wrap:wrap;}
.sc-f{padding:9px 14px;background:var(--paper2);border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.sc-pl{font-size:10px;color:var(--steel);font-weight:700;text-transform:uppercase;}
.sc-pv{font-size:16px;font-weight:700;font-family:'DM Mono',monospace;color:var(--gm);}
.sc-mg{font-size:11px;font-family:'DM Mono',monospace;color:var(--gold);font-weight:700;}

/* EXPENSE CARD */
.ec{background:var(--white);border:1px solid var(--border);border-radius:6px;padding:12px 14px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:flex-start;animation:fu .2s ease;}
.ec-cat{font-size:10px;font-weight:700;color:var(--steel);text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px;}
.ec-desc{font-size:13px;font-weight:500;}
.ec-meta{font-size:11px;color:var(--steel);margin-top:2px;}
.ec-amt{font-size:15px;font-weight:700;font-family:'DM Mono',monospace;text-align:right;}
.ec-tax{font-size:10px;color:var(--blue);font-family:'DM Mono',monospace;text-align:right;}
.ec-img{width:48px;height:48px;object-fit:cover;border-radius:4px;border:1px solid var(--border);margin-top:4px;cursor:pointer;}

/* RECEIPT CAMERA */
.cam-area{border:2px dashed var(--border);border-radius:8px;padding:24px 16px;text-align:center;cursor:pointer;transition:border-color .15s;background:var(--paper);}
.cam-area:hover{border-color:#f87171;}
.cam-icon{font-size:32px;margin-bottom:8px;}
.cam-txt{font-size:13px;color:var(--steel);}
.cam-sub{font-size:11px;color:#9ca3af;margin-top:4px;}
.img-preview-wrap{position:relative;margin-top:12px;display:none;}
.img-preview{width:100%;max-height:200px;object-fit:contain;border-radius:6px;border:1px solid var(--border);}
.img-remove{position:absolute;top:6px;right:6px;background:var(--red);color:#fff;border:none;border-radius:50%;width:24px;height:24px;font-size:14px;cursor:pointer;line-height:24px;}
.ai-badge{display:inline-flex;align-items:center;gap:4px;background:var(--blue-l);color:var(--blue);font-size:10px;font-weight:700;padding:3px 8px;border-radius:12px;margin-left:6px;}
.ai-status{font-size:11px;color:var(--steel);margin-top:6px;min-height:16px;}
.ai-status.loading{color:var(--blue);}
.ai-status.done{color:var(--gm);}
.ai-status.err{color:var(--red);}

/* API KEY BANNER */
.apikey-banner{background:var(--gold-l);border:1px solid #d97706;border-radius:6px;padding:12px 14px;margin-bottom:14px;display:flex;align-items:flex-start;gap:10px;}
.apikey-banner .icon{font-size:18px;flex-shrink:0;}
.apikey-banner .text{font-size:12px;color:var(--gold);line-height:1.5;}
.apikey-banner .text strong{display:block;font-size:13px;margin-bottom:2px;}
.apikey-input-row{display:flex;gap:8px;margin-top:8px;}
.apikey-input-row input{flex:1;padding:7px 10px;border:1px solid #d97706;border-radius:4px;font-size:12px;font-family:'DM Mono',monospace;background:#fff;}
.apikey-input-row button{padding:7px 12px;background:var(--gold);color:#fff;border:none;border-radius:4px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Noto Sans JP',sans-serif;white-space:nowrap;}

/* QUOTE CARD */
.qc{background:var(--white);border:1px solid var(--border);border-radius:6px;overflow:hidden;margin-bottom:10px;box-shadow:0 1px 3px rgba(0,0,0,.05);animation:fu .2s ease;}
.qc-h{background:var(--ink2);padding:10px 14px;display:flex;justify-content:space-between;align-items:flex-start;}
.qc-n{font-size:14px;font-weight:700;color:#fff;}
.qc-d{font-size:10px;color:#9ca3af;font-family:'DM Mono',monospace;margin-top:2px;}
.qc-b{padding:10px 14px;}
.qc-r{display:flex;justify-content:space-between;font-size:12px;color:var(--steel);margin-bottom:3px;}
.qc-r .qv{font-family:'DM Mono',monospace;font-weight:600;color:var(--ink);}
.qc-f{padding:9px 14px;background:var(--paper2);border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}

/* ACC TABLE */
.at{background:var(--white);border:1px solid var(--border);border-radius:6px;overflow:hidden;margin-bottom:16px;}
.ar{display:flex;justify-content:space-between;align-items:center;padding:10px 14px;border-bottom:1px solid var(--paper3);font-size:13px;}
.ar:last-child{border-bottom:none;}
.ar.hd{background:var(--paper2);font-size:10px;font-weight:700;letter-spacing:.08em;color:var(--steel);text-transform:uppercase;}
.ar.tot{background:var(--ink);}
.ar.tot .al{color:#9ca3af;font-size:12px;}
.ar.tot .av{color:#86efac;font-size:16px;font-family:'DM Mono',monospace;font-weight:700;}
.ar.sub{background:var(--paper2);}
.al{color:var(--steel);}
.av{font-family:'DM Mono',monospace;font-weight:600;color:var(--ink);}
.av.pos{color:var(--gm);}.av.neg{color:var(--red);}.av.blue{color:var(--blue);}

/* INVOICE */
.inv-box{background:var(--white);border:2px solid var(--ink);border-radius:6px;padding:20px;margin-bottom:16px;font-size:13px;}
.inv-title{font-size:22px;font-weight:900;letter-spacing:.05em;margin-bottom:4px;}
.inv-sub{font-size:11px;color:var(--steel);font-family:'DM Mono',monospace;}
.inv-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:16px 0;}
.inv-fl{font-size:10px;color:var(--steel);text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px;}
.inv-fv{font-size:13px;font-weight:500;border-bottom:1px solid var(--border);padding-bottom:4px;min-height:22px;}
.inv-tbl{width:100%;border-collapse:collapse;margin:12px 0;font-size:12px;}
.inv-tbl th{background:var(--ink);color:#fff;padding:6px 10px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.08em;}
.inv-tbl td{padding:7px 10px;border-bottom:1px solid var(--paper3);}
.inv-tbl tr:last-child td{border-bottom:none;}
.inv-tbl .rt{text-align:right;font-family:'DM Mono',monospace;}
.inv-tots{border-top:2px solid var(--ink);padding-top:10px;}
.itr{display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px;}
.itr.grand{font-size:17px;font-weight:700;border-top:1px solid var(--border);margin-top:6px;padding-top:6px;}
.itr .tv{font-family:'DM Mono',monospace;font-weight:600;}
.itr.grand .tv{color:var(--red);}
.inv-reg{font-size:11px;color:var(--steel);font-family:'DM Mono',monospace;margin-top:12px;border-top:1px solid var(--border);padding-top:8px;}

/* EXPORT */
.exs{background:var(--white);border:1px solid var(--border);border-radius:6px;padding:16px;margin-bottom:12px;}
.ext{font-size:13px;font-weight:700;color:var(--ink);margin-bottom:3px;}
.exd{font-size:11px;color:var(--steel);margin-bottom:10px;line-height:1.5;}

/* MODAL */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:500;display:none;align-items:center;justify-content:center;padding:16px;}
.modal-bg.open{display:flex;}
.modal{background:#fff;border-radius:8px;padding:0;max-width:400px;width:100%;overflow:hidden;}
.modal-h{background:var(--ink);padding:14px 16px;display:flex;justify-content:space-between;align-items:center;}
.modal-h span{font-size:14px;font-weight:700;color:#fff;}
.modal-close{background:none;border:none;color:#9ca3af;font-size:20px;cursor:pointer;line-height:1;}
.modal-body{padding:16px;}
.modal-img{width:100%;border-radius:6px;margin-bottom:12px;}

.empty{text-align:center;padding:32px 16px;color:var(--steel);}
.empty-icon{font-size:36px;margin-bottom:8px;}
.empty-txt{font-size:13px;}
</style>
</head>
<body>

<!-- PWA INSTALL BANNER -->
<div id="installBanner" style="display:none;position:fixed;bottom:0;left:0;right:0;background:#111827;color:#fff;padding:12px 16px;z-index:999;align-items:center;justify-content:space-between;gap:10px;border-top:2px solid #f87171;">
  <div style="font-size:13px;font-weight:700;">📲 ホーム画面に追加するともっと便利</div>
  <div style="display:flex;gap:8px;flex-shrink:0;">
    <button onclick="installApp()" style="background:#f87171;color:#fff;border:none;border-radius:4px;padding:7px 14px;font-size:12px;font-weight:700;cursor:pointer;font-family:'Noto Sans JP',sans-serif;">追加する</button>
    <button onclick="document.getElementById('installBanner').style.display='none'" style="background:none;border:1px solid #374151;color:#9ca3af;border-radius:4px;padding:7px 12px;font-size:12px;cursor:pointer;">後で</button>
  </div>
</div>

<div class="hdr">
  <div class="hdr-top">
    <div><div class="logo">現場<em>帳</em></div><div class="logo-sub">GENBA-CHO v4 — 建設業会計</div></div>
    <div class="tax-tog" onclick="toggleTax()">表示: <span id="taxLabel">税抜</span></div>
  </div>
  <div class="nav">
    <div class="tab active" onclick="showPage('sites',this)">現場</div>
    <div class="tab" onclick="showPage('receipt',this)">領収書</div>
    <div class="tab" onclick="showPage('expenses',this)">経費</div>
    <div class="tab" onclick="showPage('quote',this)">見積書</div>
    <div class="tab" onclick="showPage('invoice',this)">請求書</div>
    <div class="tab" onclick="showPage('accounting',this)">会計</div>
    <div class="tab" onclick="showPage('export',this)">出力</div>
  </div>
</div>

<div class="sbar">
  <div class="si"><div class="sl">現場数</div><div class="sv" id="sumCount">0</div></div>
  <div class="si"><div class="sl">売上</div><div class="sv red" id="sumRev">¥0</div></div>
  <div class="si"><div class="sl">経費</div><div class="sv" id="sumExp">¥0</div></div>
  <div class="si"><div class="sl">粗利</div><div class="sv green" id="sumProfit">¥0</div></div>
  <div class="si"><div class="sl">消費税</div><div class="sv gold" id="sumTax">¥0</div></div>
</div>

<!-- ══════════ SITES ══════════ -->
<div class="page active" id="page-sites">
  <div class="sec">現場を追加</div>
  <div class="card">
    <div class="fr"><label class="fl">現場名</label><input class="fi" id="sName" placeholder="例：○○工事" type="text"></div>
    <div class="fr"><label class="fl">請負金額（税抜）</label><input class="fi mono" id="sRev" placeholder="0" type="number" oninput="updateSP()"></div>
    <div class="g2">
      <div class="fr"><label class="fl">外注工賃（税抜）</label><input class="fi mono" id="sSub" placeholder="0" type="number" oninput="updateSP()"></div>
      <div class="fr"><label class="fl">材料費（税抜）</label><input class="fi mono" id="sMat" placeholder="0" type="number" oninput="updateSP()"></div>
    </div>
    <div class="g2">
      <div class="fr"><label class="fl">着手日</label><input class="fi" id="sStart" type="date"></div>
      <div class="fr"><label class="fl">完了予定日</label><input class="fi" id="sEnd" type="date"></div>
    </div>
    <div class="fr">
      <label class="fl">入金条件</label>
      <div class="chips" id="payChips">
        <div class="chip" onclick="selChip(this,'pay','完了後即時')">完了後即時</div>
        <div class="chip" onclick="selChip(this,'pay','月末締翌月払')">月末締翌月払</div>
        <div class="chip" onclick="selChip(this,'pay','検収後30日')">検収後30日</div>
        <div class="chip" onclick="selChip(this,'pay','前払い50%')">前払い50%</div>
        <div class="chip" onclick="selChip(this,'pay','手形90日')">手形90日</div>
        <div class="chip" onclick="selChip(this,'pay','その他')">その他</div>
      </div>
    </div>
    <div class="prev" id="sitePrev" style="display:none">
      <div class="pr"><span>請負（税抜）</span><span class="pv" id="pRev">—</span></div>
      <div class="pr ptax"><span>消費税10%</span><span class="pv" id="pRevTax">—</span></div>
      <div class="pr"><span>請負（税込）</span><span class="pv" id="pRevInc">—</span></div>
      <div class="pr" style="margin-top:6px"><span>外注工賃</span><span class="pv" id="pSub">—</span></div>
      <div class="pr"><span>材料費</span><span class="pv" id="pMat">—</span></div>
      <div class="pr tot"><span>粗利益（税抜）</span><span class="pv" id="pProfit">—</span></div>
      <div class="pr prate"><span>粗利率</span><span class="pv" id="pMargin">—</span></div>
    </div>
    <div style="margin-top:14px"><button class="btn btn-p" onclick="addSite()">＋ 現場を追加</button></div>
  </div>
  <div class="sec">現場一覧</div>
  <div id="sitesList"><div class="empty" id="sitesEmpty"><div class="empty-icon">🏗️</div><div class="empty-txt">現場がまだありません</div></div></div>
</div>

<!-- ══════════ RECEIPT ══════════ -->
<div class="page" id="page-receipt">
  <div class="sec">領収書を撮影・登録</div>

  <!-- API KEY BANNER -->
  <div class="apikey-banner" id="apiBanner">
    <div class="icon">🤖</div>
    <div class="text">
      <strong>AI自動読み取り — APIキー設定で有効化</strong>
      Claude AIが領収書の金額・日付・店名を自動で読み取り経費に入力します。APIキーを設定すると今すぐ使えます。
      <div class="apikey-input-row">
        <input type="password" id="apiKeyInput" placeholder="sk-ant-api03-...">
        <button onclick="saveApiKey()">保存して有効化</button>
      </div>
    </div>
  </div>

  <div class="card">
    <!-- CAMERA INPUT -->
    <div class="fr">
